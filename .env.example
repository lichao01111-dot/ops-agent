# ===== OpsAgent Configuration =====

# --- LLM Provider (openai / anthropic / deepseek / qwen) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# --- OpenAI Compatible (also works for DeepSeek, Qwen, vLLM) ---
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- DeepSeek (OpenAI compatible) ---
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# --- Qwen (DashScope / OpenAI compatible) ---
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-max
# OPENAI_API_KEY=sk-your-dashscope-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Private Deployment (vLLM / Ollama) ---
# LLM_PROVIDER=openai
# LLM_MODEL=deepseek-v3
# OPENAI_API_KEY=not-needed
# OPENAI_BASE_URL=http://your-vllm-server:8000/v1

# --- Router LLM (lightweight, for intent classification) ---
ROUTER_LLM_PROVIDER=openai
ROUTER_LLM_MODEL=gpt-4o-mini
ROUTER_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Jenkins ---
JENKINS_URL=http://jenkins.example.com
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token

# --- Kubernetes ---
# Leave empty to use default kubeconfig (~/.kube/config)
KUBECONFIG_PATH=
K8S_ALLOWED_NAMESPACES=dev,staging,default
K8S_READONLY_NAMESPACES=prod,production

# --- Log System ---
LOG_PROVIDER=elasticsearch
ELASTICSEARCH_URL=http://elasticsearch.example.com:9200
# LOKI_URL=http://loki.example.com:3100

# --- Vector DB ---
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Security ---
SECRET_KEY=change-me-to-random-string
ADMIN_USERS=admin@company.com
