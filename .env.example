# ===== OpsAgent Configuration =====

# --- LLM Provider (google / openai / anthropic / deepseek / qwen) ---
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash

# --- Google AI ---
GOOGLE_API_KEY=your-google-api-key
# 留空时使用官方默认 endpoint
GOOGLE_API_BASE_URL=

# --- OpenAI Compatible (also works for DeepSeek, Qwen, vLLM) ---
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- DeepSeek (OpenAI compatible) ---
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# --- Qwen (DashScope / OpenAI compatible) ---
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-max
# OPENAI_API_KEY=sk-your-dashscope-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Private Deployment (vLLM / Ollama) ---
# LLM_PROVIDER=openai
# LLM_MODEL=deepseek-v3
# OPENAI_API_KEY=not-needed
# OPENAI_BASE_URL=http://your-vllm-server:8000/v1

# --- Router LLM (lightweight, for intent classification) ---
ROUTER_LLM_PROVIDER=google
ROUTER_LLM_MODEL=gemini-2.0-flash-lite
ROUTER_GOOGLE_API_BASE_URL=
ROUTER_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Jenkins ---
JENKINS_URL=http://jenkins.example.com
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token

# --- Kubernetes ---
# Leave empty to use default kubeconfig (~/.kube/config)
KUBECONFIG_PATH=
K8S_ALLOWED_NAMESPACES=dev,staging,default
K8S_READONLY_NAMESPACES=prod,production

# --- Log System ---
LOG_PROVIDER=elasticsearch
ELASTICSEARCH_URL=http://elasticsearch.example.com:9200
# LOKI_URL=http://loki.example.com:3100

# --- Knowledge Base / PostgreSQL + pgvector ---
KNOWLEDGE_BACKEND=postgres
KNOWLEDGE_PG_DSN=postgresql://ops_agent:ops_agent@localhost:5433/ops_agent
KNOWLEDGE_PG_SCHEMA=public
KNOWLEDGE_COLLECTION=ops_knowledge

# --- Formal Embedding API ---
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_API_KEY=
# 留空时 Google provider 回退到 GOOGLE_API_BASE_URL，OpenAI-compatible 回退到 OPENAI_BASE_URL
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=32

# --- Local Embedding Fallback (仅开发调试) ---
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Ingestion Pipeline ---
KNOWLEDGE_UPLOAD_DIR=./data/uploads
KNOWLEDGE_CHUNK_SIZE=1000
KNOWLEDGE_CHUNK_OVERLAP=200

# --- Redis ---
REDIS_URL=redis://localhost:6380/0

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Security ---
SECRET_KEY=change-me-to-random-string
ADMIN_USERS=admin@company.com

# --- Langfuse Observability (default off) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_SAMPLE_RATE=0.1
LANGFUSE_ENABLED_VERTICALS=ops
LANGFUSE_RELEASE=
LANGFUSE_LLM_OBSERVATION_ENABLED=true
LANGFUSE_REDACT_LLM_INPUT=false
LANGFUSE_REDACT_LLM_OUTPUT=false
LANGFUSE_PROMPT_MANAGEMENT_ENABLED=false
LANGFUSE_PROMPT_LABEL=production
LANGFUSE_PROMPT_FALLBACK_ON_ERROR=true
